# ——— Сонник: выкладка на стороне Фотостраны (свой Node / контейнер / за прокси) ———
# Скопируйте в .env.local рядом с приложением или в переменные окружения процесса node.
#
# Важно у прокси (nginx / balancer / DDoS-Guard перед приложением):
# - Пробрасывайте все пути включая /admin и /api/admin без редиректа на другой домен.
# - Для HTTPS за прокси: X-Forwarded-Proto: https, Host: ваш хост сонника.
# Иначе /admin/login и API админки дадут 404 или «ломаные» абсолютные ссылки.

NEXT_PUBLIC_SITE_URL=https://sonnik.fotostrana.ru
NEXT_PUBLIC_SITE_NAME=Сонник Фотостраны

NEXT_PUBLIC_DEPLOY_TARGET=fotostrana

NEXT_PUBLIC_PUBLISHER_NAME=Фотострана
NEXT_PUBLIC_PUBLISHER_URL=https://www.fotostrana.ru

NEXT_PUBLIC_FS_CTA_URL=https://www.fotostrana.ru

NEXT_PUBLIC_YANDEX_METRIKA_ID=108988416

AUTH_SECRET=
ADMIN_PASSWORD_HASH=

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# На своём сервере можно использовать Vercel Blob (тот же токен из Vercel) —
# или оставить пустым: тогда сохранение пойдёт в файловое content/*.json там, где разрешено.
BLOB_READ_WRITE_TOKEN=
