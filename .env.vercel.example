# ——— Сонник: выкладка на Vercel ———
# Скопируйте в .env.local или задайте в Vercel → Settings → Environment Variables.
#
# Совет: в Production укажите свой домен (напр. sonnik.fotostrana.ru), когда привязан к проекту,
# чтобы canonical/OG/шары не указывали на *.vercel.app без необходимости.

# Корень приложения для шаринга, sitemap и JSON-LD
NEXT_PUBLIC_SITE_URL=https://sonnik-fotostrana1.vercel.app
NEXT_PUBLIC_SITE_NAME=Сонник Фотостраны

# Зона размещения (для логики/комментариев в коде при необходимости)
NEXT_PUBLIC_DEPLOY_TARGET=vercel

# Издатель в разметке статьи
NEXT_PUBLIC_PUBLISHER_NAME=Фотострана
NEXT_PUBLIC_PUBLISHER_URL=https://www.fotostrana.ru

# Кнопка «Вернуться в Фотострану»
NEXT_PUBLIC_FS_CTA_URL=https://www.fotostrana.ru

# Яндекс.Метрика
NEXT_PUBLIC_YANDEX_METRIKA_ID=108988416

# Админка: на Vercel обязательны AUTH_SECRET (≥16) и ADMIN_PASSWORD_HASH (bcrypt)
# npm run hash-admin-password
AUTH_SECRET=
ADMIN_PASSWORD_HASH=

# DeepSeek для генерации статей
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Сохранение статей через Vercel Blob (без токена на Vercel saveArticles упадёт)
BLOB_READ_WRITE_TOKEN=
